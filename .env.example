# Local server
PORT=3000
MEDIA_DB_PATH=data/media.sqlite

# TMDB metadata. Configure either the API key or the read access token.
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_READ_ACCESS_TOKEN=

# Gemini recommendations and assisted PDF importing.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_MODEL_FALLBACKS=gemini-flash-lite-latest,gemini-3.1-flash-lite,gemini-3.1-flash-lite-preview,gemma-4-26b-a4b-it
GEMINI_HTTP_REFERER=http://localhost:5173/
